# Copy to .env and fill in. NEVER commit real secrets. Read via os.environ only.

# ----- Serving (OpenAI-compatible base URLs) -----
# Primary: vLLM (the engine used on Blackwell sm120). Off-GPU: SERVING_BACKEND=mock.
# Local dev fallback: Ollama. (SGLang is unused on Blackwell — no sm120 kernel.)
SERVING_BACKEND=vllm                         # vllm | ollama | mock | sglang(unused on sm120)
OPENAI_BASE_URL=http://localhost:30000/v1
OPENAI_API_KEY=EMPTY                         # vLLM ignores it; keep non-empty
MODEL_ID=Qwen/Qwen3-8B

VLLM_BASE_URL=http://localhost:30000/v1
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen3:8b

# ----- Hugging Face (model + dataset downloads) -----
HF_TOKEN=
HF_HOME=~/.cache/huggingface

# ----- Milvus (OPTIONAL — production RAG swap; the run used an in-memory index) -----
MILVUS_URI=http://localhost:19530
MILVUS_TOKEN=

# ----- Langfuse (OPTIONAL observability; degrades to no-op when unset) -----
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ----- API (auth + rate limit) -----
API_AUTH_TOKEN=changeme-dev-token
JWT_SECRET=changeme-dev-secret
RATE_LIMIT_PER_MINUTE=60

# ----- Misc -----
LOG_LEVEL=INFO
